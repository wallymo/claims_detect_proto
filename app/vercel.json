{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/",
      "destination": "/mkg3",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://claimsdetectproto-production.up.railway.app/api/:path*"
    },
    {
      "source": "/:path((?!api(?:/|$))(?!.*\\.[^/]+$).*)",
      "destination": "/index.html"
    }
  ]
}
