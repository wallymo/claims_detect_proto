# ===========================================
# Frontend Environment Variables (app/.env.local)
# ===========================================

# AI API Keys (client-side - for development/testing only)
# WARNING: These are exposed to the browser - use server-side proxy in production
VITE_GEMINI_API_KEY=
VITE_ANTHROPIC_API_KEY=
VITE_OPENAI_API_KEY=

# Logging Configuration
# Level: error | warn | info | debug
VITE_LOG_LEVEL=info
# Format: json | pretty (json recommended for production)
VITE_LOG_FORMAT=pretty

# Claim dedup rollout controls (frontend)
# Toggle aggressive near-dedup; set to false for exact-only rollback.
VITE_CLAIM_NEAR_DEDUP_ENABLED=true
# Optional debug trace for dedup decisions (verbose logs).
VITE_CLAIM_DEDUP_DEBUG=false
# Optional tuning for aggressive near-dedup matching.
VITE_CLAIM_NEAR_DEDUP_SIMILARITY=0.72
VITE_CLAIM_NEAR_DEDUP_OVERLAP=0.85

# Sentry Error Tracking (optional)
# Get your DSN from https://sentry.io
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
