# ===========================================
# Frontend Environment Variables (app/.env.local)
# ===========================================

# AI API Keys (client-side - for development/testing only)
# WARNING: These are exposed to the browser - use server-side proxy in production
VITE_GEMINI_API_KEY=
VITE_ANTHROPIC_API_KEY=
VITE_OPENAI_API_KEY=

# Logging Configuration
# Level: error | warn | info | debug
VITE_LOG_LEVEL=info
# Format: json | pretty (json recommended for production)
VITE_LOG_FORMAT=pretty

# Claim dedup rollout controls (frontend)
# Toggle aggressive near-dedup; set to false for exact-only rollback.
VITE_CLAIM_NEAR_DEDUP_ENABLED=true
# Optional debug trace for dedup decisions (verbose logs).
VITE_CLAIM_DEDUP_DEBUG=false
# Optional tuning for aggressive near-dedup matching.
VITE_CLAIM_NEAR_DEDUP_SIMILARITY=0.72
VITE_CLAIM_NEAR_DEDUP_OVERLAP=0.85

# Persistent analysis cache (frontend)
VITE_PERSISTENT_ANALYSIS_CACHE_ENABLED=true
VITE_ANALYSIS_CACHE_VERSION=2026-02-20
VITE_ANALYSIS_CACHE_STORE_DIAGNOSTICS=false

# Sentry Error Tracking (optional)
# Get your DSN from https://sentry.io
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development

# ===========================================
# Backend Environment Variables (backend/.env)
# ===========================================

# Reference analysis provider
# Values: gemini | llamaparse
REFERENCE_ANALYSIS_PROVIDER=gemini

# Gemini fallback / default provider
VITE_GEMINI_API_KEY=

# Llama Cloud / LlamaParse
LLAMA_CLOUD_API_KEY=
LLAMA_PARSE_TIER=agentic
LLAMA_PARSE_VERSION=latest

# /mkg3 evidence suggestion lane
# Values: gemini | llamaparse
EVIDENCE_SUGGESTION_PROVIDER=gemini

# /mkg3 global orphan-slide breakdown inside the PyMuPDF pipeline
# Values: heuristic | llamaparse
PYMUPDF_GLOBAL_ANNOTATION_PROVIDER=heuristic
PYMUPDF_GLOBAL_ANNOTATION_MAX_PAGES=6
PYMUPDF_TIMEOUT_MS=180000

# Persistent analysis cache (backend)
ANALYSIS_CACHE_ENABLED=true
ANALYSIS_CACHE_TTL_DAYS=30
ANALYSIS_CACHE_MAX_ROWS=500
ANALYSIS_CACHE_STORE_DIAGNOSTICS=false
ANALYSIS_CACHE_MAX_PAYLOAD_BYTES=3000000
