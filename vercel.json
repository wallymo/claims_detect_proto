{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm --prefix app install",
  "buildCommand": "npm --prefix app run build",
  "outputDirectory": "app/dist",
  "redirects": [
    {
      "source": "/",
      "destination": "/mkg2",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/:path((?!api(?:/|$))(?!.*\\.[^/]+$).*)",
      "destination": "/index.html"
    }
  ]
}
